{
  "explorer.excludeGitIgnore": true,
  "files.watcherExclude": {
    "**/.fvm": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/*.code-search": true,
    "**/ios/.symlinks/**": true
  },
  "files.readonlyInclude": {
    "**/*.g.dart": true,
    "**/*.freezed.dart": true,
    "**/*.gr.dart": true,
    "**/*.config.dart": true
  },
  "js/ts.implicitProjectConfig.checkJs": false,
  "eslint.workingDirectories": [
    "flureadium/assets/_helper_scripts/"
  ],
  "dart.lineLength": 120,
  "[dart]": {
    "editor.rulers": [
      120
    ],
  },
  "cSpell.enabledFileTypes": {
    "dart": true,
  },
  "cSpell.ignorePaths": [
    "**/.pub-cache/**",
    "**/pubspec.lock",
    "**/node_modules/**",
    "**/vscode-extension/**",
    "**/.git/objects/**",
    "**/assets/l10n/**",
    "!**/assets/l10n/**/da.yaml",
    "**/assets/feeds/**",
    "**/project.pbxproj",
    "**/Podfile.lock"
  ],
  "cSpell.language": "en,da,sv",
  "cSpell.words": [
    "acsm",
    "androidx",
    "ascii",
    "Ascii",
    "charsets",
    "Charsets",
    "comicbook",
    "CSASCII",
    "dartx",
    "dfunc",
    "divina",
    "epub",
    "Epub",
    "EPUB",
    "epubcfi",
    "fimber",
    "Fimber",
    "jsonable",
    "kotlin",
    "kotlinx",
    "lcpl",
    "Mantano",
    "mediatype",
    "opds",
    "Opds",
    "podfile",
    "podspec",
    "prefs",
    "Prefs",
    "readium",
    "reflowable",
    "rels",
    "RWPM",
    "subcollection",
    "Subcollection",
    "subcollections"
  ],
  "java.configuration.updateBuildConfiguration": "interactive"
}
